rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can read/write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Providers: anyone logged in can read approved providers
    // Only the owner can create; only admin functions update status
    match /providers/{providerId} {
      allow read: if request.auth != null && resource.data.status == 'approved';
      allow create: if request.auth != null;
      allow update: if false; // Only via Admin SDK / Cloud Functions
    }

    // Requests: anyone logged in can read open requests and create
    match /requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
